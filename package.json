    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^7.120.4",
    "@vee-validate/i18n": "^4.15.1",
    "@vee-validate/rules": "^4.15.1",
    "@vueform/slider": "^2.1.10",
    "@vueuse/core": "^14.1.0",
    "apollo-upload-client": "^18.0.1",
    "assertion-error": "^2.0.1",
    "core-js": "^3.47.0",
    "cypress": "^15.9.0",
    "d3": "^7.9.0",
    "deepdash": "^5.3.9",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "graphql": "^16.12.0",
    "jwt-decode": "^4.0.0",
    "luxon": "^3.7.2",
    "omit-deep": "^0.3.0",
    "pretty-bytes": "^7.1.0",
    "vee-validate": "^4.15.1",
    "video.js": "^8.23.6",
    "vue": "^3.5.26",
    "vue-apollo": "^3.1.2",
    "vue-class-component": "^8.0.0-rc.1",
    "vue-cookie-next": "^1.3.0",
    "vue-meta": "^3.0.0-alpha.10",
    "vue-property-decorator": "^10.0.0-rc.3",
    "vue-router": "^4.6.4",
    "vuex": "^4.1.0",
    "vuex-persistedstate": "^4.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^5.0.3",
    "@graphql-codegen/cli": "^5.0.7",
